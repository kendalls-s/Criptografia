func opcion_cifrar_vigenere(): void {
    limpiar_pantalla();
    print("========== CIFRADO VIGENERE ==========");
    print("");
    
    let intentos: int = 0;
    let mensaje: string = "";
    let clave: string = "";
    let valido_mensaje: bool = false;
    let valido_clave: bool = false;
    
    while (valido_mensaje == false && intentos < 3) {
        print("Ingrese el mensaje a CIFRAR: ");
        mensaje = input();
        
        if (validar_no_vacio(mensaje)) {
            valido_mensaje = true;
        } else {
            intentos = intentos + 1;
            if (intentos < 3) {
                print("Intente nuevamente.");
            }
        }
    }
    
    if (valido_mensaje == false) {
        print("ERROR: Demasiados intentos fallidos.");
        print("Presione Enter para continuar...");
        input();
        return;
    }
    
    intentos = 0;
    while (valido_clave == false && intentos < 3) {
        print("");
