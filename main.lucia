func opcion_letras_a_numeros(): void {
    limpiar_pantalla();
    print("========== LETRAS -> NUMEROS ==========");
    print("(A=1, B=2, C=3, ..., Z=26)");
    print("");
    
    let intentos: int = 0;
    let texto: string = "";
    let valido: bool = false;
    
    while (valido == false && intentos < 3) {
        print("Ingrese la palabra o frase: ");
        texto = input();
        
        if (validar_no_vacio(texto)) {
            valido = true;
        } else {
            intentos = intentos + 1;
            if (intentos < 3) {
                print("Intente nuevamente.");
            }
        }
    }
    
    if (valido) {
        let resultado: string = letras_a_numeros(texto);
        print("");
        print("RESULTADO:");
        print("Texto:   " + texto);
        print("Numeros: " + resultado);
    } else {
        print("ERROR: Demasiados intentos fallidos.");
    }
    
    print("");
    print("Presione Enter para continuar...");
    input();
}

func opcion_numeros_a_letras(): void {
    limpiar_pantalla();
    print("========== NUMEROS -> LETRAS ==========");
    print("(1=A, 2=B, 3=C, ..., 26=Z)");
    print("");
    print("Ejemplo: 8 15 12 1 = HOLA");
    print("");
    
    let intentos: int = 0;
    let numeros: string = "";
    let valido: bool = false;
    
    while (valido == false && intentos < 3) {
        print("Ingrese los numeros (separados por espacio): ");
        numeros = input();
        
        if (validar_solo_numeros_y_espacios(numeros)) {
            valido = true;
        } else {
            intentos = intentos + 1;
            if (intentos < 3) {
                print("Intente nuevamente.");
            }
        }
    }
    
    if (valido) {
        let resultado: string = numeros_a_letras(numeros);
        print("");
        print("RESULTADO:");
        print("Numeros: " + numeros);
        print("Letras:  " + resultado);
    } else {
        print("ERROR: Demasiados intentos fallidos.");
    }
    
    print("");
    print("Presione Enter para continuar...");
    input();
}

// =====================================================
// PROGRAMA PRINCIPAL
// =====================================================

func main(): void {
    let opcion: string = "";
    let valido: bool = false;
    let intentos: int = 0;
    
    while (opcion != "7") {
        mostrar_menu();
        
        intentos = 0;
        valido = false;
        while (valido == false && intentos < 3) {
            print("Seleccione una opcion (1-7): ");
            opcion = input();
            
            if (opcion == "1") { valido = true; }
            else if (opcion == "2") { valido = true; }
            else if (opcion == "3") { valido = true; }
            else if (opcion == "4") { valido = true; }
            else if (opcion == "5") { valido = true; }
            else if (opcion == "6") { valido = true; }
            else if (opcion == "7") { valido = true; }
            else {
                intentos = intentos + 1;
                if (intentos < 3) {
                    print("ERROR: Opcion invalida. Intente nuevamente.");
                }
            }
        }
        
        if (intentos >= 3) {
            print("ERROR: Demasiados intentos fallidos.");
            print("Presione Enter para salir...");
            input();
            break;
        }
        
        if (opcion == "1") {
            opcion_cifrar_cesar();
        } else if (opcion == "2") {
            opcion_descifrar_cesar();
        } else if (opcion == "3") {
            opcion_cifrar_vigenere();
        } else if (opcion == "4") {
            opcion_descifrar_vigenere();
        } else if (opcion == "5") {
            opcion_letras_a_numeros();
        } else if (opcion == "6") {
            opcion_numeros_a_letras();
        }
    }
    
    limpiar_pantalla();
    print("=================================================");
    print("         GRACIAS POR USAR EL PROGRAMA!");
    print("=================================================");
}

// Ejecutar programa
main();